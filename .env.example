ENVIRONMENT=development

DB_HOST=postgres
DB_PORT=5432
DB_NAME=riverbend
DB_USER=riverbend_app
DB_PASSWORD=changeme

REDIS_URL=redis://redis:6379/0

PAYER_API_URL=https://edi.example.com/v1/eligibility
PAYER_API_KEY=changeme

HL7_FEED_HOST=hl7.example.org
HL7_FEED_PORT=2575

SESSION_SECRET=changeme

# LLM client (libs/llm_client) — provider-swappable, defaults to the
# no-network fake provider. Only set real credentials for a provider you
# actually intend to use.
LLM_PROVIDER=fake
OPENAI_API_KEY=changeme
OPENAI_MODEL=changeme
ANTHROPIC_API_KEY=changeme
ANTHROPIC_MODEL=changeme
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=changeme
# Bedrock credentials are NOT set here — boto3 reads them from the standard
# AWS credential chain (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY,
# AWS_BEARER_TOKEN_BEDROCK, or a configured profile).
BEDROCK_MODEL_ID=changeme
AWS_REGION=us-east-1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_MAX_TOKENS_PER_REQUEST=2000
LLM_MONTHLY_TOKEN_BUDGET=1000000

# Embedding client (libs/embedding_client) — provider-swappable, defaults to
# the no-network fake provider. No cloud embedding provider (OpenAI/
# Anthropic/Bedrock) is implemented by design; "ollama" is the local/offline
# option for anyone actually running the retrieval-eval corpus pipeline
# (libs/rag_corpus), so corpus/query text never leaves the environment.
EMBEDDING_PROVIDER=fake
OLLAMA_EMBED_MODEL=changeme
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=3
EMBEDDING_MONTHLY_TOKEN_BUDGET=1000000

# RAG corpus builder (libs/rag_corpus) — config-driven size cap and cache
# location for the retrieval-eval harness's corpus. Built from db/seed's
# checked-in fixtures only, never a live DB or the client's raw export.
RAG_CORPUS_MAX_RECORDS=200
RAG_EMBEDDING_CACHE_DIR=.cache/rag_embeddings

# Retrieval-eval harness (libs/rag_eval) — measurement only; see
# docs/planning/retrieval-eval-report-07-08-2026.md.
RAG_EVAL_TOP_K=1
